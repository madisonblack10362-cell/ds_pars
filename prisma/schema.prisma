generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("admin") // admin, editor, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Source {
  id         String   @id @default(uuid())
  sourceType String   @default("") // discord, telegram, vk, website
  serverName String   @default("")
  sourceId   String   @default("")
  channelName String  @default("")
  enabled    Boolean  @default(true)
  extra      String   @default("{}") // JSON extra data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  news NewsItem[]
}

model NewsItem {
  id               String   @id @default(uuid())
  sourceId         String
  source           Source   @relation(fields: [sourceId], references: [id])
  externalId       String   @default("")
  serverName       String   @default("")
  channelName      String   @default("")
  author           String   @default("")
  title            String   @default("")
  content          String   @default("")
  summary          String   @default("")
  formattedPost    String   @default("")
  newsType         String   @default("") // wipe, update, event, maintenance, patch, other
  priority         String   @default("low") // high, medium, low
  status           String   @default("pending") // pending, approved, rejected, published
  images           String   @default("[]") // JSON array of image URLs
  links            String   @default("[]") // JSON array of links
  publishedAtSource String?
  publishedAt      DateTime?
  scheduledAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Settings {
  key       String   @id // use key as primary key
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  level     String   @default("info")
  module    String   @default("")
  message   String
  details   String   @default("")
  createdAt DateTime @default(now())
}
