# ============================================
# DayZ News Monitor — Web Panel Configuration
# ============================================

# URL вашего Web App, развёрнутого на Vercel
# После деплоя замените на ваш URL
WEB_APP_URL=https://your-project.vercel.app

# API ключ для авторизации запросов от бота к веб-панели
# Задайте любой сложный пароль (обязательно для production)
BOT_API_KEY=your-secret-api-key-change-me

# Telegram Bot Token (для валидации initData в Web App)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# JWT Secret (для генерации токенов авторизации)
JWT_SECRET=your-jwt-secret-change-me

# Database URL (для Vercel Postgres или Neon)
# SQLite для локальной разработки:
DATABASE_URL=file:./db/dashboard.db
# PostgreSQL для Vercel (раскомментируйте при подключении):
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# NVIDIA NIM API (для AI анализа)
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your-nvidia-api-key
