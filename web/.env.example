# ===========================================
# DayZ News Monitor Web Panel — Environment
# ===========================================

# JWT Secret for auth tokens
JWT_SECRET=change-me-to-random-string

# Telegram Bot Token (for Web App initData validation)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Bot API Key (for webhook authorization from bot)
BOT_API_KEY=

# Database URL
DATABASE_URL=file:./db/dashboard.db

# NVIDIA API (optional, for AI settings display)
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
